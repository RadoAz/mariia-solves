---
import "../styles/global.css";
import { site, getContent } from "../data/content";
const locale = Astro.currentLocale ?? site.defaultLocale;
const c = getContent(locale);
const description = c.description;
const ogImage = new URL("/og.jpg", Astro.site).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name} — {c.tagline}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${site.name} — ${c.tagline}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === "uk" ? "uk_UA" : "en_US"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${site.name} — ${c.tagline}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" hreflang="en" href={new URL("/", Astro.site).href} />
    <link rel="alternate" hreflang="uk" href={new URL("/uk/", Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site).href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-milk text-ink antialiased">
    <slot />
  </body>
</html>
