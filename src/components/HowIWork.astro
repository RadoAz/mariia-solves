---
import { getContent } from "../data/content";
const { howIWork } = getContent(Astro.currentLocale);
---
<section id="how" class="bg-bronze-dark text-milk">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <div class="text-center">
      <p class="label text-milk/70">{howIWork.label}</p>
      <h2 class="mt-3 font-serif text-3xl leading-tight md:text-5xl">{howIWork.heading}</h2>
    </div>

    <ol class="mt-14 grid gap-px overflow-hidden rounded-sm md:grid-cols-5">
      {howIWork.steps.map((step, i) => (
        <li class="flex flex-col items-center gap-4 bg-bronze/20 px-5 py-8 text-center">
          <span class="flex h-12 w-12 items-center justify-center rounded-full border border-milk/40 font-serif text-2xl text-milk">
            {i + 1}
          </span>
          <p class="text-sm leading-relaxed text-milk/90">{step}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
