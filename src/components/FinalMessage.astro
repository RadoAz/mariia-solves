---
import { getContent } from "../data/content";
const { finalMessage } = getContent(Astro.currentLocale);
---
<section class="bg-sand">
  <div class="mx-auto max-w-4xl px-6 py-24 text-center">
    <div class="mx-auto h-px w-10 bg-bronze"></div>
    <p class="mt-8 font-serif text-3xl leading-snug text-ink md:text-4xl">{finalMessage.text}</p>
  </div>
</section>
