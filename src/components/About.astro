---
import { Image } from "astro:assets";
import aboutImg from "../assets/about.jpg";
import { getContent } from "../data/content";
const { about } = getContent(Astro.currentLocale);
---
<section id="about" class="bg-sand">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-20 md:grid-cols-2">
    <div>
      <p class="label">{about.label}</p>
      <h2 class="mt-3 font-serif text-3xl leading-tight md:text-4xl">
        {about.paragraphs[0]}
      </h2>
      <p class="mt-6 max-w-md text-sm leading-relaxed text-muted">{about.paragraphs[1]}</p>
      <p class="mt-4 max-w-md font-serif text-xl italic leading-relaxed text-bronze-dark">{about.paragraphs[2]}</p>
    </div>
    <Image src={aboutImg} alt="Mariia at work" widths={[480, 800]} sizes="(min-width: 768px) 50vw, 100vw"
      class="h-72 w-full rounded-sm object-cover md:h-96" />
  </div>
</section>
