---
import { getContent, site } from "../data/content";
const locale = Astro.currentLocale ?? site.defaultLocale;
const c = getContent(locale);
const langs = [
  { code: "en", label: "EN", href: "/" },
  { code: "uk", label: "UK", href: "/uk/" },
];
---
<header class="sticky top-0 z-50 border-b border-bronze/15 bg-milk/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={locale === "uk" ? "/uk/" : "/"} class="font-serif text-xl leading-none tracking-wide">
      MARIIA<br /><span class="text-bronze-dark">SOLVES</span>
    </a>
    <nav class="hidden gap-7 md:flex" aria-label="Main navigation">
      {c.nav.map((i) => (
        <a href={i.href} class="label hover:text-bronze">{i.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1 text-xs uppercase tracking-widest" aria-label="Language">
        {langs.map((l, idx) => (
          <>
            {idx > 0 && <span class="text-bronze/40">/</span>}
            <a href={l.href}
               class={`transition hover:text-bronze ${locale === l.code ? "text-bronze-dark font-semibold" : "text-muted"}`}
               aria-current={locale === l.code ? "true" : undefined}>{l.label}</a>
          </>
        ))}
      </div>
      <a href="#contact"
         class="hidden rounded-sm border border-bronze px-4 py-2 text-xs uppercase tracking-widest text-bronze-dark transition hover:bg-bronze hover:text-milk sm:inline-block">
        {c.ui.bookConsult}
      </a>
    </div>
  </div>
</header>
